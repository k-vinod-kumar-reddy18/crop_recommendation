import pickle
import os

# Define the path where the model was saved by cell FQNJcc7YHu1e
model_file_path = "model/crop_model.pkl"

# Check if the model file exists, as FQNJcc7YHu1e should have created it.
if os.path.exists(model_file_path):
    # Load the model from the file
    xgb_model = pickle.load(open(model_file_path, "rb"))
    print("Model loaded successfully from model/crop_model.pkl.")

    # Now, save this loaded xgb_model to the root directory as crop_model.pkl
    with open("crop_model.pkl", "wb") as f:
        pickle.dump(xgb_model, f)
    print("Model saved as crop_model.pkl in the root directory.")
else:
    print(f"Error: Model file not found at {model_file_path}.")
    print("Please ensure cell FQNJcc7YHu1e was executed successfully to save the model.")
